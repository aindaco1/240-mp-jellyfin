{
  "id": "com.240mp.ambient_mode",
  "name": "Loop",
  "display_order": 60,
  "icon": "assets/images/logo.svg",
  "entry_point_qml": "views/Root.qml",
  "settings": [
    {
      "key": "enabled",
      "label": "ENABLED",
      "type": "toggle",
      "default": "ON"
    },
    {
      "key": "media_directory",
      "label": "Media Directory",
      "type": "directory_browser",
      "default": "~/Desktop"
    },
    {
      "key": "shuffle_video",
      "label": "Shuffle Video Playback",
      "type": "toggle",
      "default": "OFF"
    },
    {
      "key": "shuffle_audio",
      "label": "Shuffle Audio Playback",
      "type": "toggle",
      "default": "OFF"
    },
    {
      "key": "auto_launch",
      "label": "Auto-Launch Playback",
      "type": "toggle",
      "default": "OFF",
      "description": "Start Loop immediately when this module opens."
    }
  ]
}
