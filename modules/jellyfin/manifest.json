{
  "id": "com.240mp.jellyfin",
  "name": "Jellyfin",
  "display_order": 10,
  "icon": "assets/images/logo.svg",
  "entry_point_qml": "views/Root.qml",
  "settings": [
    {
      "key": "enabled",
      "label": "Enabled",
      "type": "toggle",
      "default": "ON"
    },
    {
      "key": "video_quality",
      "label": "Video Quality",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "getVideoQualities",
      "default": "direct",
      "requires_auth": true
    },
    {
      "key": "resume_playback",
      "label": "Resume Playback",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "get_resume_playback_options",
      "default": "ask",
      "requires_auth": true
    },
    {
      "key": "logout",
      "label": "Sign out",
      "type": "action",
      "action_slot": "logout",
      "requires_auth": true
    }
  ]
}
